{
  "version": "7.0",
  "data_api_version": "3.0",
  "routing_model": {
    "PROGRESO": ["SUCCESS"]
  },
  "screens": [
    {
      "id": "PROGRESO",
      "title": "Tu progreso",
      "terminal": false,
      "data": {
        "linea_fase": { "type": "string", "__example__": "Fase 0 - Cuna - dia 12 de 30 (40%)" },
        "linea_tiempo": { "type": "string", "__example__": "Tiempo de boca: 35 min acumulados" },
        "linea_palabras": { "type": "string", "__example__": "Palabras tuyas: 8" },
        "linea_hitos": { "type": "string", "__example__": "Hitos viscerales: 1 desbloqueado." },
        "linea_novela": { "type": "string", "__example__": "Novela: aun no inicia." },
        "linea_mision": { "type": "string", "__example__": "Mision de hoy: aun no asignada." }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "Tu progreso esta semana" },
          { "type": "TextSubheading", "text": "${data.linea_fase}" },
          { "type": "TextBody", "text": "${data.linea_tiempo}" },
          { "type": "TextBody", "text": "${data.linea_palabras}" },
          { "type": "TextBody", "text": "${data.linea_hitos}" },
          { "type": "TextBody", "text": "${data.linea_novela}" },
          { "type": "TextBody", "text": "${data.linea_mision}" },
          {
            "type": "Footer",
            "label": "Cerrar",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {}
            }
          }
        ]
      }
    },
    {
      "id": "SUCCESS",
      "title": "Cerrado",
      "terminal": true,
      "success": true,
      "data": {
        "extension_message_response": {
          "type": "object",
          "__example__": { "params": { "status": "progress_closed" } }
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextBody", "text": "Sigue asi." }
        ]
      }
    }
  ]
}
