{
  "version": "7.0",
  "data_api_version": "3.0",
  "routing_model": {
    "FRASE": ["SUCCESS"]
  },
  "screens": [
    {
      "id": "FRASE",
      "title": "Pronunciacion",
      "terminal": false,
      "data": {
        "target_phrase": { "type": "string", "__example__": "I would like a coffee, please." },
        "linea_titulo": { "type": "string", "__example__": "Test de pronunciacion" },
        "linea_instruccion": { "type": "string", "__example__": "Lee esta frase en ingles..." },
        "linea_pista": { "type": "string", "__example__": "Habla con calma y vocaliza claro." }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "${data.linea_titulo}" },
          { "type": "TextBody", "text": "${data.linea_instruccion}" },
          { "type": "TextSubheading", "text": "${data.target_phrase}" },
          { "type": "TextCaption", "text": "${data.linea_pista}" },
          {
            "type": "Footer",
            "label": "Estoy listo",
            "on-click-action": {
              "name": "data_exchange",
              "payload": {
                "target_phrase": "${data.target_phrase}"
              }
            }
          }
        ]
      }
    },
    {
      "id": "SUCCESS",
      "title": "Esperando audio",
      "terminal": true,
      "success": true,
      "data": {
        "extension_message_response": {
          "type": "object",
          "__example__": { "params": { "status": "awaiting_audio" } }
        }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "Listo" },
          { "type": "TextBody", "text": "Envia ahora un audio en WhatsApp diciendo la frase." }
        ]
      }
    }
  ]
}
