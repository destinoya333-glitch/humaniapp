{
  "version": "7.0",
  "screens": [
    {
      "id": "FRASE",
      "title": "Pronunciacion",
      "terminal": true,
      "success": true,
      "data": {
        "target_phrase": { "type": "string", "__example__": "I would like a coffee, please." },
        "linea_titulo": { "type": "string", "__example__": "Test de pronunciacion" },
        "linea_instruccion": { "type": "string", "__example__": "Lee esta frase en ingles..." },
        "linea_pista": { "type": "string", "__example__": "Habla con calma y vocaliza claro." }
      },
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "${data.linea_titulo}" },
          { "type": "TextBody", "text": "${data.linea_instruccion}" },
          { "type": "TextSubheading", "text": "${data.target_phrase}" },
          { "type": "TextCaption", "text": "${data.linea_pista}" },
          {
            "type": "Footer",
            "label": "Estoy listo",
            "on-click-action": {
              "name": "complete",
              "payload": {
                "status": "awaiting_audio",
                "target_phrase": "${data.target_phrase}"
              }
            }
          }
        ]
      }
    }
  ]
}
