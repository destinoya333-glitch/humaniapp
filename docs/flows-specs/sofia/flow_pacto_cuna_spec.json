{
  "version": "7.0",
  "screens": [
    {
      "id": "PACTO",
      "title": "Pacto Cuna",
      "terminal": true,
      "success": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "Pacto Cuna" },
          { "type": "TextBody", "text": "Antes de empezar, necesito conocerte. Solo me toma 60 segundos." },
          {
            "type": "Form",
            "name": "form_pacto",
            "init-values": {},
            "children": [
              {
                "type": "TextInput",
                "name": "name",
                "label": "Tu nombre",
                "input-type": "text",
                "required": true,
                "min-chars": 2,
                "max-chars": 30
              },
              {
                "type": "TextInput",
                "name": "city",
                "label": "Ciudad donde vives",
                "input-type": "text",
                "required": true,
                "min-chars": 2,
                "max-chars": 50
              },
              {
                "type": "RadioButtonsGroup",
                "name": "motivation",
                "label": "Por qué quieres aprender inglés",
                "required": true,
                "data-source": [
                  { "id": "Trabajo", "title": "Trabajo" },
                  { "id": "Viajar al extranjero", "title": "Viajar al extranjero" },
                  { "id": "Ver series sin subtitulos", "title": "Ver series sin subtítulos" },
                  { "id": "Hablarle a mi familia o hijos", "title": "Hablarle a mi familia o hijos" },
                  { "id": "Otro", "title": "Otro" }
                ]
              },
              {
                "type": "RadioButtonsGroup",
                "name": "minutes_per_day",
                "label": "Minutos al día que vas a dedicar",
                "required": true,
                "data-source": [
                  { "id": "5", "title": "5 minutos" },
                  { "id": "10", "title": "10 minutos (recomendado)" },
                  { "id": "20", "title": "20 minutos" }
                ]
              },
              {
                "type": "OptIn",
                "name": "committed",
                "label": "Me comprometo a 30 días de Fase Cuna (escuchar sin presión)",
                "required": true
              },
              {
                "type": "Footer",
                "label": "Sellar Pacto",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "status": "pacto_sealed",
                    "name": "${form.name}",
                    "city": "${form.city}",
                    "motivation": "${form.motivation}",
                    "minutes_per_day": "${form.minutes_per_day}",
                    "committed": "${form.committed}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
