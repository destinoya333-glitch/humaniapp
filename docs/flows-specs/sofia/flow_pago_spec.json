{
  "version": "7.0",
  "routing_model": {
    "COMPARATIVA": ["DETALLES", "PAGO"],
    "DETALLES": ["PAGO"]
  },
  "screens": [
    {
      "id": "COMPARATIVA",
      "title": "Plan Sofia",
      "terminal": false,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "Sofia Regular o Sofia Premium" },
          { "type": "TextBody", "text": "✨ Regular — S/39/mes o S/349/año (ahorras S/119)\nAudios diarios ilimitados con voz Nova, novela personal, chat con Sofia." },
          { "type": "TextBody", "text": "🌟 Premium — S/89/mes o S/799/año (ahorras S/269)\nTodo lo de Regular + Voz ElevenLabs (45 min/mes), capítulos novela acelerados, sello Cuna nativo USA." },
          { "type": "TextBody", "text": "🛡️ Garantía Klaric 6 meses: si en 6 meses no progresas, te devolvemos cada centavo." },
          {
            "type": "Footer",
            "label": "¿Qué significa todo esto?",
            "on-click-action": {
              "name": "navigate",
              "next": { "type": "screen", "name": "DETALLES" },
              "payload": {}
            }
          }
        ]
      }
    },
    {
      "id": "DETALLES",
      "title": "Detalles del método",
      "terminal": false,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "Conceptos clave" },
          { "type": "TextSubheading", "text": "🍼 Método Cuna" },
          { "type": "TextBody", "text": "Aprendes inglés como aprendiste español de bebé: escuchando primero, sin traducir, sin presión. 30 días de Fase Cuna + audios diarios." },
          { "type": "TextSubheading", "text": "📖 Novela personal" },
          { "type": "TextBody", "text": "TÚ eres el protagonista. Cada capítulo se genera con tu nombre, ciudad y motivación. Aprendes inglés viviendo TU historia, no la de un libro." },
          { "type": "TextSubheading", "text": "🇺🇸 Sello Cuna nativo USA (solo Premium)" },
          { "type": "TextBody", "text": "Audios con voz humana de hablantes nativos USA, no IA. Te entrena el oído al acento real que escucharás en películas, trabajo, viajes." },
          { "type": "TextSubheading", "text": "🎙️ Voz Nova vs ElevenLabs" },
          { "type": "TextBody", "text": "Nova (OpenAI): voz IA fluida, en TODOS los planes ilimitada.\nElevenLabs (Premium): voz IA premium con entonación humana, 45 min/mes para tus momentos hero." },
          { "type": "TextSubheading", "text": "🛡️ Garantía Klaric 6 meses" },
          { "type": "TextBody", "text": "Si en 6 meses cumpliendo tu Pacto Cuna no progresas, te devolvemos el 100% de lo pagado. Sin preguntas. Inspirada en la filosofía de Jürgen Klaric: 'vendele a la mente, no a la gente'." },
          {
            "type": "Footer",
            "label": "Continuar al pago",
            "on-click-action": {
              "name": "navigate",
              "next": { "type": "screen", "name": "PAGO" },
              "payload": {}
            }
          }
        ]
      }
    },
    {
      "id": "PAGO",
      "title": "Pago Yape",
      "terminal": true,
      "success": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "Pago por Yape" },
          { "type": "TextSubheading", "text": "Yapea a Percy Roj* — 998 102 258" },
          { "type": "TextBody", "text": "Selecciona tu plan y yapea el monto exacto. Detectamos tu pago automáticamente." },
          {
            "type": "Form",
            "name": "form_pago",
            "init-values": {},
            "children": [
              {
                "type": "RadioButtonsGroup",
                "name": "plan_billing",
                "label": "Tu plan",
                "required": true,
                "data-source": [
                  { "id": "cuna_monthly", "title": "Regular Mensual · S/39" },
                  { "id": "cuna_yearly", "title": "Regular Anual · S/349 (ahorras S/119)" },
                  { "id": "premium_monthly", "title": "Premium Mensual · S/89" },
                  { "id": "premium_yearly", "title": "Premium Anual · S/799 (ahorras S/269)" }
                ]
              },
              {
                "type": "Footer",
                "label": "Confirmar plan",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "status": "payment_pending_validation",
                    "plan_billing": "${form.plan_billing}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
