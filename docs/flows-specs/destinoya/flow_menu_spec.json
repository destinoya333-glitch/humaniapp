{
  "version": "7.0",
  "screens": [
    {
      "id": "MENU",
      "title": "TuDestinoYa",
      "terminal": true,
      "success": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "¿Qué necesitas hoy?" },
          { "type": "TextBody", "text": "Elige el servicio que más te ayude. Tras tu elección, te muestro planes y precios." },
          {
            "type": "Form",
            "name": "form_menu",
            "init-values": {},
            "children": [
              {
                "type": "RadioButtonsGroup",
                "name": "servicio",
                "label": "Elige un servicio",
                "required": true,
                "data-source": [
                  { "id": "esoterico", "title": "🔮 DestinoYA Esotérico" },
                  { "id": "profesional", "title": "💼 Área Profesional" },
                  { "id": "rapidas", "title": "⚡ Soluciones Rápidas" },
                  { "id": "vip", "title": "✨ DestinoYA VIP" },
                  { "id": "gratuita", "title": "🎁 Lectura Gratuita (1 vez)" }
                ]
              },
              {
                "type": "Footer",
                "label": "Continuar",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "status": "menu_seleccionado",
                    "servicio": "${form.servicio}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
