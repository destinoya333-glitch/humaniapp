{
  "version": "7.0",
  "screens": [
    {
      "id": "PAGO",
      "title": "Pago Yape",
      "terminal": true,
      "success": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "Pago por Yape" },
          { "type": "TextSubheading", "text": "Yapea a Percy Roj* — 998 102 258" },
          { "type": "TextBody", "text": "Selecciona el plan que pagaste. Detectamos tu Yape automáticamente." },
          {
            "type": "Form",
            "name": "form_pago",
            "init-values": {},
            "children": [
              {
                "type": "RadioButtonsGroup",
                "name": "plan",
                "label": "Plan",
                "required": true,
                "data-source": [
                  { "id": "basico", "title": "Básico · S/3 · 3 secciones" },
                  { "id": "intermedio", "title": "Intermedio · S/6 · 4 secciones" },
                  { "id": "premium", "title": "Premium · S/9 · 6 secciones" },
                  { "id": "pro", "title": "PRO · S/9.90 · profundo" },
                  { "id": "vip_mensual", "title": "VIP Mensual · S/18" },
                  { "id": "vip_anual", "title": "VIP Anual · S/63" }
                ]
              },
              {
                "type": "Footer",
                "label": "Confirmar plan",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "status": "pago_registrado",
                    "plan": "${form.plan}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
