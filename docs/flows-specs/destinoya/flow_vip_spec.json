{
  "version": "7.0",
  "routing_model": {
    "VIP_INFO": ["VIP_PAGO"]
  },
  "screens": [
    {
      "id": "VIP_INFO",
      "title": "VIP",
      "terminal": false,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "DestinoYA VIP" },
          { "type": "TextBody", "text": "Acceso ilimitado a TODOS los servicios (Esotérico, Profesional, Rápidas)." },
          { "type": "TextBody", "text": "✨ Mensual — S/18 por 30 días, consultas ilimitadas." },
          { "type": "TextBody", "text": "🌟 Anual — S/63 por 365 días, consultas ilimitadas (ahorras S/153)." },
          { "type": "TextBody", "text": "Garantía: si no quedas satisfecho, te devolvemos lo pagado." },
          {
            "type": "Footer",
            "label": "Continuar al pago",
            "on-click-action": {
              "name": "navigate",
              "next": { "type": "screen", "name": "VIP_PAGO" },
              "payload": {}
            }
          }
        ]
      }
    },
    {
      "id": "VIP_PAGO",
      "title": "Pago VIP",
      "terminal": true,
      "success": true,
      "layout": {
        "type": "SingleColumnLayout",
        "children": [
          { "type": "TextHeading", "text": "Pago VIP por Yape" },
          { "type": "TextSubheading", "text": "Yapea a Percy Roj* — 998 102 258" },
          { "type": "TextBody", "text": "Selecciona tu plan y yapea el monto exacto. Detectamos tu pago automáticamente." },
          {
            "type": "Form",
            "name": "form_vip",
            "init-values": {},
            "children": [
              {
                "type": "RadioButtonsGroup",
                "name": "plan",
                "label": "Plan VIP",
                "required": true,
                "data-source": [
                  { "id": "vip_mensual", "title": "Mensual · S/18 · 30 días" },
                  { "id": "vip_anual", "title": "Anual · S/63 · 365 días (ahorras S/153)" }
                ]
              },
              {
                "type": "Footer",
                "label": "Activar VIP",
                "on-click-action": {
                  "name": "complete",
                  "payload": {
                    "status": "vip_listo",
                    "plan": "${form.plan}"
                  }
                }
              }
            ]
          }
        ]
      }
    }
  ]
}
